    "print(\"=== The total number of entries must be the max(len(MAIN_DF), len(REF_DF))\")\n",
    "assert max(len(MAIN_DF), len(REF_DF)) == len(JOIN_DF)\n",
    "\n",
    "print()\n",
    "print(\"(Saving joined dataset...)\")\n",
    "JOIN_DF.to_csv(OUT_JOINED_DATASET, index=False)\n",
    "\n",
    "print()\n",
    "print(\"=== JOIN_DF info\")\n",
    "print(JOIN_DF.info())"
   ]
